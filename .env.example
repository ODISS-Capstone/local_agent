# Copy this file to `.env` and fill in local secrets.
# Do not commit `.env`.

# ipTIME C500G ONVIF-issued main stream.
# URL-encode special characters in the password when placing it inside RTSP_URL.
# Example for password `neworder2030!!`: `neworder2030%21%21`
RTSP_URL=rtsp://USER:PASSWORD@192.168.0.75:554/onvif1

# Gemini OCR
GEMINI_API_KEY=

# Optional: Hugging Face higher rate limits for model downloads.
HF_TOKEN=

# Optional: GLM-OCR MaaS fallback, if provider is changed to `glmocr`.
ZHIPU_API_KEY=
